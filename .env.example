# Copy this file to .env before running Docker Compose.
# These values are for local teaching/demo use only.

COMPOSE_PROJECT_NAME=db-platform-reference

POSTGRES_DB=library_demo
POSTGRES_USER=library_user
POSTGRES_PASSWORD=library_password
POSTGRES_HOST=localhost
# Host-side PostgreSQL port. Change it if that port is already in use.
POSTGRES_PORT=55432
POSTGRES_HOST_PORT=55432

MONGO_URI=mongodb://localhost:27018
MONGO_DB=exam_files
MONGO_GRIDFS_BUCKET=exam_pdfs
MONGO_HOST_PORT=27018
MONGO_INTERNAL_PORT=27017

# Host ports are the ports you open in your browser from your computer.
API_PORT=8000
FRONTEND_PORT=8080

# Internal ports are the ports containers use to talk to each other.
# Most students should not need to change these.
API_INTERNAL_PORT=8000
FRONTEND_INTERNAL_PORT=5173
